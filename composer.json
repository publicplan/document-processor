{
    "name": "publicplan/document-processor",
    "description": "Standalone DOCX to HTML processor for PHP 8.4+",
    "type": "library",
    "keywords": ["docx", "html", "converter", "word", "document"],
    "license": "MIT",
    "authors": [
        {
            "name": "Publicplan GmbH",
            "email": "info@publicplan.de"
        }
    ],
    "require": {
        "php": ">=8.4",
        "phpoffice/phpword": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Publicplan\\DocumentProcessor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Publicplan\\DocumentProcessor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
